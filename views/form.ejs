<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><% if (type === 'item' || type === 'edit-item') { %>Item<% } else { %>Category<% } %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <% if (type === 'item' || type === 'edit-item') { %>
        <h2><% if (type === 'edit-item') { %>Edit<% } else { %>Create a new<% } %> item:</h2>
        <form action="<% if (type === 'edit-item') { %>/edit-item<% } else { %>/new-item<% } %>" method="post">
            <% if (type === 'edit-item') { %>
                <input type="hidden" name="item_id" value="<%= item.item_id %>" />
            <% } else { %>
                <input type="hidden" name="category_id" value="<%= category_id %>" />
            <% } %>
            <div>
                <label>Name: </label>
                <input name="item_name" placeholder="Enter item name" value="<% if (type === 'edit-item') { %><%= item.item_name %><% } %>" required />
            </div>
            <div>
                <label>Price: </label>
                <input name="price" type="number" step="0.01" placeholder="Enter price" value="<% if (type === 'edit-item') { %><%= item.price %><% } %>" required />
            </div>
            <button>Submit</button>
        </form>
    <% } else { %>
        <h2><% if (type === 'edit-category') { %>Edit<% } else { %>Create a<% } %> category:</h2>
        <form action="<% if (type === 'edit-category') { %>/edit-category<% } else { %>/new<% } %>" method="post">
            <% if (type === 'edit-category') { %>
                <input type="hidden" name="category_id" value="<%= category.category_id %>" />
            <% } %>
            <div>
                <label>Name: </label>
                <input name="category_name" placeholder="Enter category name" value="<% if (type === 'edit-category') { %><%= category.category_name %><% } %>" required />
            </div>
            <button>Submit</button>
        </form>
    <% } %>
</body>
</html>
